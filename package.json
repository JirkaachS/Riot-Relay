{
  "name": "riot-relay",
  "productName": "Riot Relay",
  "version": "1.4.3",
  "description": "A secure multi-game Riot account switcher with encrypted credentials, identity-bound sessions, unified stats, inventory tools, and privacy-first presence controls.",
  "main": "electron/main.js",
  "author": "Riot Relay contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JirkaachS/Riot-Relay.git"
  },
  "homepage": "https://jirkaachs.github.io/Riot-Relay/",
  "bugs": {
    "url": "https://github.com/JirkaachS/Riot-Relay/issues"
  },
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "dev:tools": "electron . --dev --devtools",
    "test": "node --test test/*.test.js",
    "docs:capture": "electron tools/docs-capture-main.js",
    "pack": "electron-builder --dir --config electron-builder.nsis.yml",
    "dist:nsis": "electron-builder --config electron-builder.nsis.yml --publish never",
    "dist:msi": "electron-builder --config electron-builder.msi.yml --publish never",
    "dist:win": "npm run dist:nsis && npm run dist:msi",
    "release:nsis": "electron-builder --config electron-builder.nsis.yml --publish always",
    "release:msi": "electron-builder --config electron-builder.msi.yml --publish always",
    "installer:install-deps": "npm --prefix installer install",
    "installer:build": "npm run pack && npm --prefix installer run dist"
  },
  "devDependencies": {
    "electron": "43.1.1",
    "electron-builder": "26.15.3"
  },
  "dependencies": {
    "electron-updater": "6.8.9"
  },
  "allowScripts": {
    "electron-winstaller@5.4.0": true
  }
}
